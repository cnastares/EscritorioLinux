// Custom Niri configuration file preconfigured for DMS (DankMaterialShell)
// Check https://github.com/YaLTeR/niri/wiki/Configuration for details.

input {
    keyboard {
        xkb {
            // Set keyboard layout (supports Spanish and US layouts)
            layout "es,us"
            options "grp:win_space_toggle"
        }
        numlock
    }

    touchpad {
        tap
        natural-scroll
    }
}

layout {
    // Border gaps around windows in logical pixels
    gaps 12

    center-focused-column "never"

    // Default widths for window columns
    preset-column-widths {
        proportion 0.33333
        proportion 0.5
        proportion 0.66667
    }

    default-column-width { proportion 0.5; }

    focus-ring {
        width 4
        active-color "#7fc8ff"
        inactive-color "#505050"
    }

    border {
        off
    }
}

// Start DankMaterialShell (DMS) at startup
spawn-at-startup "dms" "run"

binds {
    // Launch Terminal (gnome-terminal)
    Mod+Return { spawn "gnome-terminal"; }

    // Toggle DMS Spotlight App Launcher (Super + Space or Super + D)
    Mod+Space { spawn "dms" "ipc" "call" "spotlight" "toggle"; }
    Mod+D { spawn "dms" "ipc" "call" "spotlight" "toggle"; }

    // Close focused window
    Mod+Q { close-window; }

    // Toggle floating mode (overlapping window like Windows/Ubuntu)
    Mod+T { toggle-window-floating; }

    // Window focus navigation (Super + Arrows or Super + HJKL)
    Mod+Left  { focus-column-left; }
    Mod+Right { focus-column-right; }
    Mod+Up    { focus-window-or-workspace-up; }
    Mod+Down  { focus-window-or-workspace-down; }
    
    Mod+H { focus-column-left; }
    Mod+L { focus-column-right; }
    Mod+K { focus-window-or-workspace-up; }
    Mod+J { focus-window-or-workspace-down; }

    // Move windows (Super + Ctrl + Arrows or Super + Ctrl + HJKL)
    Mod+Ctrl+Left  { move-column-left; }
    Mod+Ctrl+Right { move-column-right; }
    Mod+Ctrl+Up    { move-window-to-workspace-up; }
    Mod+Ctrl+Down  { move-window-to-workspace-down; }
    
    Mod+Ctrl+H { move-column-left; }
    Mod+Ctrl+L { move-column-right; }
    Mod+Ctrl+K { move-window-to-workspace-up; }
    Mod+Ctrl+J { move-window-to-workspace-down; }

    // Tiling Column Controls
    Mod+R { switch-preset-column-width; }
    Mod+F { maximize-column; }
    Mod+Shift+F { fullscreen-window; }

    // Workspaces Navigation (Super + Number)
    Mod+1 { focus-workspace 1; }
    Mod+2 { focus-workspace 2; }
    Mod+3 { focus-workspace 3; }
    Mod+4 { focus-workspace 4; }
    Mod+5 { focus-workspace 5; }
    Mod+6 { focus-workspace 6; }
    Mod+7 { focus-workspace 7; }
    Mod+8 { focus-workspace 8; }
    Mod+9 { focus-workspace 9; }

    // Move windows between workspaces (Super + Shift + Number)
    Mod+Shift+1 { move-column-to-workspace 1; }
    Mod+Shift+2 { move-column-to-workspace 2; }
    Mod+Shift+3 { move-column-to-workspace 3; }
    Mod+Shift+4 { move-column-to-workspace 4; }
    Mod+Shift+5 { move-column-to-workspace 5; }
    Mod+Shift+6 { move-column-to-workspace 6; }
    Mod+Shift+7 { move-column-to-workspace 7; }
    Mod+Shift+8 { move-column-to-workspace 8; }
    Mod+Shift+9 { move-column-to-workspace 9; }

    // Audio volume controls (laptop keys)
    XF86AudioRaiseVolume { spawn "wpctl" "set-volume" "@DEFAULT_AUDIO_SINK@" "0.1+"; }
    XF86AudioLowerVolume { spawn "wpctl" "set-volume" "@DEFAULT_AUDIO_SINK@" "0.1-"; }
    XF86AudioMute        { spawn "wpctl" "set-mute" "@DEFAULT_AUDIO_SINK@" "toggle"; }
    
    // Screen brightness controls (laptop keys)
    XF86MonBrightnessUp   { spawn "brightnessctl" "set" "10%+"; }
    XF86MonBrightnessDown { spawn "brightnessctl" "set" "10%-"; }

    // Minimize / restore active window to scratchpad
    Mod+M { spawn "niri-scratchpad" "create" "1"; }

    // Exit Niri Session (Log Out)
    Mod+Shift+E { quit; }
}

workspace "1"
workspace "stash"

// Window styling rules
window-rule {
    // Draw rounded window corners
    geometry-corner-radius 12
    clip-to-geometry true

    // Open all windows in traditional floating mode by default
    open-floating true
}
